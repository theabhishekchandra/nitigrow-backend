{
  "name": "nitigrow-backend",
  "version": "1.0.0",
  "description": "NitiGrow WhatsApp Marketing Platform — API Server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:worker": "node src/worker.js",
    "dev": "nodemon src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate:status": "migrate-mongo status -f migrate-mongo-config.js",
    "migrate:up": "migrate-mongo up -f migrate-mongo-config.js",
    "migrate:down": "migrate-mongo down -f migrate-mongo-config.js",
    "migrate:create": "migrate-mongo create -f migrate-mongo-config.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.1",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@sentry/node": "^10.52.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.74.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "opossum": "^9.0.0",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.6",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "migrate-mongo": "^14.0.7",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}
