# NitiGrow Backend - environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.

# ─── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# If true, this process also runs the BullMQ workers in-band. Otherwise run
# `npm run start:worker` (or the worker container) separately.
RUN_WORKER=false

# ─── Dev / Mock Mode ───────────────────────────────────────────────────────────
# Set to true to bypass ALL external API calls (WhatsApp, Razorpay, Anthropic).
# The full UI works with realistic mock data. Set false for production.
USE_MOCK=true


# MongoDB
MONGODB_URI=mongodb://localhost:27017/nitigrow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_to_different_random_secret

# Meta / WhatsApp
META_APP_ID=
META_APP_SECRET=
WEBHOOK_VERIFY_TOKEN=choose_any_random_string
WHATSAPP_API_URL=https://graph.facebook.com/v19.0

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Plan IDs from Razorpay Dashboard (Plans section)
RAZORPAY_PLAN_STARTER=plan_xxx
RAZORPAY_PLAN_GROWTH=plan_xxx
RAZORPAY_PLAN_PRO=plan_xxx
RAZORPAY_PLAN_ENTERPRISE=plan_xxx

# MinIO (File Storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=nitigrow

# Email (Resend)
RESEND_API_KEY=

# Encryption (AES-256 for storing WhatsApp tokens)
ENCRYPTION_KEY=32_char_random_key_here

# Frontend URLs (used for CORS allow-list and OAuth redirects)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
